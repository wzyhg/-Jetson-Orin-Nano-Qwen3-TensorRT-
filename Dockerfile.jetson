ARG BASE_IMAGE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /workspaces/KuiperLLama

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    git \
    libarmadillo-dev \
    libgoogle-glog-dev \
    libgtest-dev \
    libopenblas-dev \
    libsentencepiece-dev \
    ninja-build \
    pkg-config \
    python3 \
    python3-pip \
  && rm -rf /var/lib/apt/lists/*

COPY . /workspaces/KuiperLLama

ARG MODEL_SUPPORT=QWEN2
ARG CUDA_ARCHITECTURES=87
RUN cmake -S . -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_CUDA_ARCHITECTURES=${CUDA_ARCHITECTURES} \
    -DQWEN2_SUPPORT=$([ "${MODEL_SUPPORT}" = "QWEN2" ] && echo ON || echo OFF) \
    -DQWEN3_SUPPORT=$([ "${MODEL_SUPPORT}" = "QWEN3" ] && echo ON || echo OFF) \
    -DLLAMA3_SUPPORT=$([ "${MODEL_SUPPORT}" = "LLAMA3" ] && echo ON || echo OFF) \
  && cmake --build build

ENV LD_LIBRARY_PATH=/workspaces/KuiperLLama/lib:${LD_LIBRARY_PATH}

CMD ["/bin/bash"]
